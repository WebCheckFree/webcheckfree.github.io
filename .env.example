# Cloudflare Worker variables are configured in wrangler.jsonc or the Cloudflare dashboard.
# Secrets must be stored with `npx wrangler secret put NAME` and never committed.

APP_URL=https://webcheckfree.github.io
APP_NAME=WEBCHECK
GITHUB_REPOSITORY_URL=https://github.com/WebCheckFree/webcheckfree.github.io
CORS_ALLOWED_ORIGINS=https://webcheckfree.github.io,http://localhost:4173

AI_ENABLED=false
AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
AI_DAILY_REQUEST_LIMIT=3
AI_MAX_OUTPUT_TOKENS=1400

PAGESPEED_ENABLED=false
PAGESPEED_API_KEY=

AUDIT_DATA_TTL_MINUTES=60
AUDIT_MAX_RESPONSE_BYTES=350000
AUDIT_DNS_CACHE_SECONDS=300

RATE_LIMIT_QUICK_PER_HOUR=5
RATE_LIMIT_STANDARD_PER_HOUR=2
RATE_LIMIT_EXTENDED_PER_HOUR=1

# Secret: generate a strong random value and set it through Wrangler.
IP_HASH_SALT=
LOG_LEVEL=info
